<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="Python FastCGI" 
           path="*" 
           verb="*" 
           modules="FastCgiModule" 
           scriptProcessor="d:\BS\backend\venv\Scripts\python.exe|d:\BS\backend\venv\Lib\site-packages\wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
  </system.webServer>

  <appSettings>
    <!-- Required settings -->
    <add key="WSGI_HANDLER" value="backend.wsgi.application" />
    <add key="PYTHONPATH" value="C:\Path\To\Your\Backend" />
    <add key="DJANGO_SETTINGS_MODULE" value="backend.settings" />
  </appSettings>
</configuration>